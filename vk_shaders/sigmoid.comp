#version 450

// Sprint G-2d (v0.4.6) — Pure in-place sigmoid for Qwen3.6 Linear-Attn
// SsmBetaProj output (`beta = sigmoid(ssm_beta.weight @ hidden)`,
// qwen35.cpp:397).
//
// Distinct from `sigmoid_mul.comp` which fuses `data *= sigmoid(gate)`
// (used by Full-Attn gated output). The pure form is needed when the
// downstream consumer reads the activation directly with no
// multiplicative gate — Gated-Delta-Net's `beta` binding is exactly
// that.

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(binding = 0) buffer InOut { float data[]; };

layout(push_constant) uniform parameter {
    uint ne;
} p;

void main() {
    const uint i = gl_GlobalInvocationID.x;
    if (i >= p.ne) return;
    data[i] = 1.0 / (1.0 + exp(-data[i]));
}
