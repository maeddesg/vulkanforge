#version 460
#extension GL_KHR_cooperative_matrix : enable
#extension GL_KHR_memory_scope_semantics : enable
#extension GL_KHR_shader_subgroup_basic : require
#extension GL_EXT_shader_explicit_arithmetic_types : enable
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : enable
#extension GL_EXT_shader_explicit_arithmetic_types_int16 : enable
#extension GL_EXT_shader_explicit_arithmetic_types_int32 : enable
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : require
#extension GL_EXT_shader_8bit_storage : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_control_flow_attributes : enable
#extension GL_EXT_float_e4m3 : require
#extension GL_EXT_scalar_block_layout : enable

// Sprint 38 Part 2 — block-wise FP8 GEMM with native FP8 WMMA.
//
// Combines Sprint 36's block-wise scale layout (Qwen3-FP8 / DeepSeek-V3-FP8
// `weight_block_size: [128, 128]`) with Sprint 38 Part 1's native FP8
// cooperative-matrix path (`v_wmma_f32_16x16x16_fp8_fp8`).
//
// Sprint 36 folded the per-block scale into the FP8→BF16 conversion
// step during A-tile staging. The native FP8 path has no FP8→BF16
// conversion (matrix elements stay FP8 all the way to WMMA), so a
// different scale-application strategy is required.
//
// Strategy: PARTIAL ACCUMULATOR + SCALAR MULTIPLY.
//   K-loop is split into outer (k_block) and inner (8 K-steps × BK=16
//   = block_k=128). Inside one k_block all WMMAs accumulate into a
//   partial coopmat<float> accumulator. After each k_block the partial
//   is multiplied by the block scale (`partial * blk_scale`) and added
//   to the total accumulator (`total + partial`). GLSL allows
//   coopmat-times-scalar and coopmat-plus-coopmat; ACO emits 4× v_mul_f32
//   plus 4× v_add_f32 per k_block (the 16×16 acc is 4 VGPRs/lane
//   on RDNA4 Wave64). The output write is a plain copy — scale is
//   already inside total_acc.
//
// Constraints (asserted at dispatch time):
//   * BM | block_n   (n_block constant per WG; required for one
//                     scale read per k_block to be correct for the
//                     entire BM×BK tile).
//   * BK | block_k   (the inner WMMA tile lies within one k_block).
//   * block_k % BK == 0
//
// Same descriptor set + push constants as `mul_coopmat_fp8_bn32_blockwise.comp`,
// so `run_gemm_fp8_blockwise` can dispatch either shader by just swapping
// the pipeline.

#define ELEM_TYPE floate4m3_t

const uint BLOCK_SIZE = 512;
const uint BM         = 64;
const uint BN         = 32;
const uint BK         = 16;
const uint TM         = 16;
const uint TN         = 16;
const uint TK         = 16;
const uint NUM_SG     = BLOCK_SIZE / 64;

const uint A_STRIDE = BK + 1;
const uint B_STRIDE = BN + 1;
const uint C_STRIDE = BN + 1;

shared ELEM_TYPE buf_a[BM * A_STRIDE];
shared ELEM_TYPE buf_b[BK * B_STRIDE];
shared float     buf_c[BM * C_STRIDE];

layout(local_size_x = BLOCK_SIZE) in;

layout(set = 0, binding = 0) readonly  buffer BufA { uint  data_a[]; };
layout(set = 0, binding = 1) readonly  buffer BufB { float b[]; };
layout(set = 0, binding = 2) writeonly buffer BufC { float c[]; };
layout(set = 0, binding = 3) readonly  buffer ScaleBuf { float scale[]; };

layout(push_constant) uniform PC {
    uint m;
    uint n;
    uint k;
    uint stride_a;
    uint stride_b;
    uint stride_c;
    uint block_n;
    uint block_k;
    uint num_kblocks;
} pc;

void main() {
    const uint wg_m = gl_WorkGroupID.x * BM;
    const uint wg_n = gl_WorkGroupID.y * BN;
    const uint tid  = gl_LocalInvocationID.x;
    const uint sg   = gl_SubgroupID;
    const uint sg_m_idx = sg >> 1;
    const uint sg_n_idx = sg & 1u;
    const uint sg_m_base = sg_m_idx * TM;
    const uint sg_n_base = sg_n_idx * TN;

    const uint m_block_base = wg_m / pc.block_n;
    const uint scale_row_off = m_block_base * pc.num_kblocks;

    // Total accumulator collects partials across all k_blocks.
    coopmat<float, gl_ScopeSubgroup, TM, TN, gl_MatrixUseAccumulator> total_acc =
        coopmat<float, gl_ScopeSubgroup, TM, TN, gl_MatrixUseAccumulator>(0.0);
    // Partial accumulator declared once, reset to zero at the top of
    // every k_block iteration. Declaring it outside the for-loop avoids
    // any GLSL ambiguity about loop-scoped cooperative-matrix lifetime.
    coopmat<float, gl_ScopeSubgroup, TM, TN, gl_MatrixUseAccumulator> partial_acc;

    const uint a_row    = tid >> 2;
    const uint a_k_base = (tid & 3u) * 4u;
    const bool a_active = tid < 256u;

    const uint b_tid    = tid - 256u;
    const uint b_n      = b_tid >> 2;
    const uint b_k_base = (b_tid & 3u) * 4u;
    const bool b_active = tid >= 256u && tid < 384u;

    // Number of inner WMMA steps that share one block scale.
    const uint inner_steps = pc.block_k / BK;

    for (uint kb = 0u; kb < pc.num_kblocks; kb++) {
        const float blk_scale = scale[scale_row_off + kb];
        const uint  k_start    = kb * pc.block_k;

        // Reset partial accumulator at the top of each k_block.
        partial_acc =
            coopmat<float, gl_ScopeSubgroup, TM, TN, gl_MatrixUseAccumulator>(0.0);

        for (uint step = 0u; step < inner_steps; step++) {
            const uint kk = k_start + step * BK;

            // ---- A-tile: FP8 weights, no float conversion ----
            if (a_active) {
                const uint global_row    = wg_m + a_row;
                const uint a_gk_base     = kk + a_k_base;
                const bool row_in_bounds = global_row < pc.m;
                const bool a_word_full   = row_in_bounds && (a_gk_base + 3u < pc.k);
                uint word = 0u;
                if (a_word_full) {
                    const uint elem_idx = global_row * pc.stride_a + a_gk_base;
                    word = data_a[elem_idx >> 2u];
                } else if (row_in_bounds) {
                    for (uint w = 0u; w < 4u; w++) {
                        const uint gk = a_gk_base + w;
                        if (gk < pc.k) {
                            const uint ei = global_row * pc.stride_a + gk;
                            const uint sh = (ei & 3u) * 8u;
                            word |= (data_a[ei >> 2u] & (0xFFu << sh));
                        }
                    }
                }
                [[unroll]] for (uint w = 0u; w < 4u; w++) {
                    const uint8_t byte = uint8_t((word >> (w * 8u)) & 0xFFu);
                    buf_a[a_row * A_STRIDE + a_k_base + w] =
                        uintBitsToFloate4m3EXT(byte);
                }
            }

            // ---- B-tile: FP32 activations → FP8 ----
            if (b_active) {
                const uint b_gn      = wg_n + b_n;
                const uint b_gk_base = kk + b_k_base;
                const bool b_full    = b_gn < pc.n && (b_gk_base + 3u < pc.k);
                vec4 act4 = vec4(0.0);
                if (b_full) {
                    const uint base = b_gn * pc.stride_b + b_gk_base;
                    act4 = vec4(b[base + 0u], b[base + 1u], b[base + 2u], b[base + 3u]);
                } else if (b_gn < pc.n) {
                    for (uint w = 0u; w < 4u; w++) {
                        const uint gk = b_gk_base + w;
                        if (gk < pc.k) {
                            act4[w] = b[b_gn * pc.stride_b + gk];
                        }
                    }
                }
                buf_b[(b_k_base + 0u) * B_STRIDE + b_n] = ELEM_TYPE(act4.x);
                buf_b[(b_k_base + 1u) * B_STRIDE + b_n] = ELEM_TYPE(act4.y);
                buf_b[(b_k_base + 2u) * B_STRIDE + b_n] = ELEM_TYPE(act4.z);
                buf_b[(b_k_base + 3u) * B_STRIDE + b_n] = ELEM_TYPE(act4.w);
            }

            barrier();

            coopmat<ELEM_TYPE, gl_ScopeSubgroup, TM, TK, gl_MatrixUseA> matA;
            coopmat<ELEM_TYPE, gl_ScopeSubgroup, TK, TN, gl_MatrixUseB> matB;
            coopMatLoad(matA, buf_a, sg_m_base * A_STRIDE, A_STRIDE,
                        gl_CooperativeMatrixLayoutRowMajor);
            coopMatLoad(matB, buf_b, sg_n_base, B_STRIDE,
                        gl_CooperativeMatrixLayoutRowMajor);
            partial_acc = coopMatMulAdd(matA, matB, partial_acc);

            barrier();
        }

        // Apply this k_block's scale, fold into total.
        partial_acc = partial_acc * blk_scale;
        total_acc   = total_acc + partial_acc;
    }

    coopMatStore(total_acc, buf_c, sg_m_base * C_STRIDE + sg_n_base, C_STRIDE,
                 gl_CooperativeMatrixLayoutRowMajor);
    barrier();

    // Output without post-scale (already inside total_acc).
    [[unroll]] for (uint w = 0u; w < 4u; w++) {
        const uint fidx    = w * BLOCK_SIZE + tid;
        const uint m_local = fidx / BN;
        const uint n_local = fidx & (BN - 1u);
        const uint gm      = wg_m + m_local;
        const uint gn      = wg_n + n_local;
        if (gm < pc.m && gn < pc.n) {
            c[gn * pc.stride_c + gm] = buf_c[m_local * C_STRIDE + n_local];
        }
    }
}
